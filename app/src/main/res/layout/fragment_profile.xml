<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="@color/backgroundColor">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="160dp"
        android:layout_height="220dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeWidth="4dp"
        app:strokeColor="@color/white">

        <ImageView
            android:id="@+id/ivProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/foto_profil" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvDevName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dipa Tranggana"
        android:layout_marginTop="24dp"
        android:textSize="22sp"
        android:fontFamily="@font/latoblack"
        android:textColor="@color/primaryColor" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mahasiswa Sistem Informasi"
        android:textSize="18sp"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Politeknik Caltex Riau"
        android:textColor="@color/primaryDarkColor"
        android:layout_marginTop="4dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogoutProfile"
        style="@style/OceanButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="40dp"
        android:text="Keluar Aplikasi"
        android:backgroundTint="#D32F2F" />

</LinearLayout>