<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    tools:context=".Pertemuan_6.main.MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primaryColor">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@color/white"
            app:layout_scrollFlags="scroll|enterAlways" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="24dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Foto 1: Teks header dihapus (tvDashboardTitle & tvDashboardUser) -->

            <Button
                android:id="@+id/btnCustom1"
                style="@style/OceanButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Buka Web Bina Desa"
                android:backgroundTint="@color/webOrange"
                android:textColor="@android:color/white"
                app:icon="@drawable/ic_ocean_logo"
                app:iconGravity="textStart" />

            <!-- Foto 2: Mengubah kata-kata template (Lorem Ipsum) menjadi tentang UMKM Bina Desa -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selamat datang di program Bina Desa. Fokus utama kami saat ini adalah pengembangan UMKM lokal untuk meningkatkan ekonomi masyarakat desa."
                android:textSize="16sp"
                android:fontFamily="@font/latoblack"
                android:textColor="@color/primaryDarkColor"
                android:layout_marginTop="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Melalui pendampingan UMKM, kita berusaha memberikan pelatihan digital marketing dan manajemen keuangan bagi para pelaku usaha kecil."
                android:textSize="16sp"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Produk unggulan desa seperti kerajinan tangan dan olahan pangan kini mulai merambah pasar yang lebih luas berkat digitalisasi."
                android:textSize="16sp"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mari bersama-sama mendukung kemandirian ekonomi desa dengan bangga menggunakan produk-produk UMKM lokal."
                android:textSize="16sp"
                android:layout_marginTop="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/OceanButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="#D32F2F"
                android:fontFamily="@font/latoblack"
                android:text="Logout"
                android:textAllCaps="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>